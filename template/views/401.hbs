<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>401 - Unauthorized | EventSphere</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #e6f0ff 0%, #f5f7fa 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #333;
    }
    .error-container {
      text-align: center;
      max-width: 600px;
      padding: 2rem;
    }
    .error-code {
      font-size: 8rem;
      font-weight: 700;
      color: #0066cc;
      line-height: 1;
      margin-bottom: 1rem;
    }
    .error-title {
      font-size: 2.5rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }
    .error-message {
      font-size: 1.2rem;
      color: #555;
      margin-bottom: 2rem;
    }
    .btn-home {
      background: #0066cc;
      border: none;
      padding: 0.9rem 2.5rem;
      font-size: 1.1rem;
      font-weight: 500;
      transition: all 0.3s;
    }
    .btn-home:hover {
      background: #0055b3;
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 102, 204, 0.25);
    }
    .illustration {
      max-width: 380px;
      margin: 0 auto 2rem;
      opacity: 0.9;
    }
  </style>
</head>
<body>

<div class="error-container">
  <img src="https://img.freepik.com/free-vector/401-error-unauthorized-concept-illustration_114360-1893.jpg" 
       alt="401 Unauthorized Illustration" class="illustration img-fluid">

  <div class="error-code">401</div>
  <div class="error-title">Unauthorized Access</div>
  <p class="error-message">
    Sorry, you don't have permission to view this page.<br>
    Please login or check your account permissions.
  </p>

  <div class="mt-4">
    <a href="/login" class="btn btn-home text-white me-3">
      <i class="fas fa-sign-in-alt me-2"></i>Login
    </a>
    <a href="/" class="btn btn-outline-primary btn-lg">
      <i class="fas fa-home me-2"></i>Back to Home
    </a>
  </div>
</div>

</body>
</html>