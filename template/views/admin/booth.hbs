
  <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EventSphere — Manage Booths</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    body { font-family: 'Poppins', sans-serif; background: #f5f7fa; color: #333; }
    .header {
      background: #0066cc; color: white; padding: 2rem;
      border-radius: 0 0 16px 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
      margin-bottom: 2.5rem;
    }
    .table th { background: #e6f0ff; color: #0066cc; font-weight: 600; }
    .btn-manage { background: #0066cc; border: none; }
    .btn-manage:hover { background: #0055b3; }
    .booth-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
      gap: 8px; max-width: 400px; margin: 1rem auto;
    }
    .booth-item {
      aspect-ratio: 1; border-radius: 8px; display: flex;
      align-items: center; justify-content: center; font-weight: 600;
      font-size: 0.9rem; color: white; cursor: default;
    }
    .available { background: #28a745; }
    .reserved  { background: #dc3545; }
    .booth-input { max-width: 120px; }
    .snackbar {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
      min-width: 300px; padding: 14px 24px; border-radius: 8px;
      color: white; font-weight: 500; box-shadow: 0 4px 20px rgba(0,0,0,0.3);
      opacity: 0; transition: all 0.4s; z-index: 9999;
    }
    .snackbar.show { opacity: 1; }
    .snackbar.success { background: #2e7d32; }
    .snackbar.error   { background: #c62828; }
  </style>
</head>
<body>

<div class="container">
  <div class="header text-center">
    <h1 class="mb-2">Manage Booths</h1>
    <p class="lead mb-0">Create and manage booth spaces for upcoming expos</p>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <h4 class="mb-4">Select Expo to Manage Booths</h4>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>Expo Name</th>
              <th>Date</th>
              <th>Location</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="expoTableBody">
            <tr><td colspan="4" class="text-center py-4">Loading expos...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Booth Management Modal -->
<div class="modal fade" id="boothModal" tabindex="-1" aria-labelledby="boothModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="boothModalLabel">Create Booths – <span id="expoTitle"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">

        <!-- Create Form -->
        <form id="createBoothForm" class="row g-3 mb-5" novalidate>
          <div class="col-md-4">
            <label for="boothNumber" class="form-label">Booth Number <span class="text-danger">*</span></label>
            <input type="text" class="form-control booth-input" id="boothNumber" placeholder="e.g. A-05" required>
            <div class="invalid-feedback">Booth number is required</div>
          </div>

          <div class="col-md-4">
            <label for="boothSize" class="form-label">Size</label>
            <select class="form-select" id="boothSize">
              <option value="Small">Small</option>
              <option value="Medium" selected>Medium</option>
              <option value="Large">Large</option>
            </select>
          </div>

          <div class="col-md-4">
            <label for="boothStatus" class="form-label">Status</label>
            <select class="form-select" id="boothStatus">
              <option value="Available" selected>Available</option>
              <option value="Reserved">Reserved</option>
            </select>
          </div>

          <div class="col-12 mt-3">
            <button type="submit" class="btn btn-create px-4" id="createBoothBtn">
              <i class="fas fa-plus me-2"></i>Create Booth
            </button>
          </div>
        </form>

        <!-- Existing Booths -->
        <h5 class="mb-3">Existing Booths</h5>
        <div class="table-responsive mb-4">
          <table class="table table-sm table-bordered">
            <thead>
              <tr>
                <th>Booth No</th>
                <th>Size</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody id="boothsTableBody">
              <tr><td colspan="3" class="text-center">Loading booths...</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Grid Preview -->
        <h6 class="mb-3 text-muted">Booth Grid Preview</h6>
        <div class="booth-grid" id="boothGrid"></div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Snackbar ───────────────────────────────────────
function showSnackbar(message, type = 'success') {
  const snack = document.createElement('div');
  snack.className = `snackbar ${type} show`;
  snack.textContent = message;
  document.body.appendChild(snack);
  setTimeout(() => snack.classList.remove('show'), 3200);
  setTimeout(() => snack.remove(), 3700);
}

// ── Fetch all expos ───────────────────────────────────────
async function loadExpos() {
  const tbody = document.getElementById('expoTableBody');
  tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4">Loading expos...</td></tr>';

  try {
    const res = await fetch('/api/admin/expo/get', { credentials: 'include' });
    const data = await res.json();

    if (!data.success) throw new Error(data.message || 'Failed to load expos');

    tbody.innerHTML = '';

    data.data.forEach(expo => {
      const dateStr = new Date(expo.date).toLocaleDateString('en-PK', {
        day: 'numeric', month: 'short', year: 'numeric'
      });

      const row = document.createElement('tr');
      row.innerHTML = `
        <td>${expo.title}</td>
        <td>${dateStr}</td>
        <td>${expo.location}</td>
        <td>
          <button class="btn btn-manage btn-sm px-3 manage-booth-btn" 
                  data-id="${expo._id}" 
                  data-name="${expo.title}">
            Manage Booths
          </button>
        </td>
      `;
      tbody.appendChild(row);
    });

  } catch (err) {
    console.error(err);
    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-danger">Failed to load expos</td></tr>';
    showSnackbar('Could not load expos. Please try again.', 'error');
  }
}

// ── Fetch booths for expo ───────────────────────────────────────
async function loadBoothsForExpo(expoId, expoName) {
  document.getElementById('expoTitle').textContent = expoName;

  const tbody = document.getElementById('boothsTableBody');
  const grid = document.getElementById('boothGrid');
  tbody.innerHTML = '<tr><td colspan="3" class="text-center">Loading booths...</td></tr>';
  grid.innerHTML = '';

  try {
    const res = await fetch('/api/admin/expos-booths', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ expoId })
    });

    const data = await res.json();

    if (!data.success) throw new Error(data.message || 'Failed to load booths');

    const booths = data.data || [];

    // Auto-suggest next number
    let nextNum = 1;
    if (booths.length > 0) {
      const last = booths[booths.length - 1].boothNumber;
      const numPart = parseInt(last.replace(/\D/g, '')) || 0;
      nextNum = numPart + 1;
    }

    document.getElementById('boothNumber').value = nextNum.toString().padStart(2, '0');

    // Render list
    tbody.innerHTML = '';
    if (booths.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="text-center">No booths created yet.</td></tr>';
    } else {
      booths.forEach(b => {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td><strong>${b.boothNumber}</strong></td>
          <td>${b.size || '—'}</td>
          <td>
            <span class="badge bg-${b.status === 'Available' ? 'success' : 'danger'}">
              ${b.status}
            </span>
          </td>
        `;
        tbody.appendChild(row);
      });
    }

    // Render grid
    grid.innerHTML = '';
    booths.forEach(b => {
      const div = document.createElement('div');
      div.className = `booth-item ${b.status.toLowerCase()}`;
      div.textContent = b.boothNumber;
      grid.appendChild(div);
    });

  } catch (err) {
    console.error(err);
    tbody.innerHTML = '<tr><td colspan="3" class="text-center text-danger">Failed to load booths</td></tr>';
    showSnackbar('Could not load booths. Please try again.', 'error');
  }
}

// ── Create Booth ───────────────────────────────────────
const boothForm = document.getElementById('createBoothForm');
const createBtn = document.getElementById('createBoothBtn');

let MyExpoId;
boothForm.addEventListener('submit', async e => {
  e.preventDefault();

  if (!boothForm.checkValidity()) {
    boothForm.classList.add('was-validated');
    return;
  }

  //const expoId = document.querySelector('.manage-booth-btn[data-id]')?.dataset.id; // current expo
  const expoId = MyExpoId;
  if (!expoId) return showSnackbar('No expo selected', 'error');

  const payload = {
    expoId,
    boothNumber: document.getElementById('boothNumber').value.trim(),
    size: document.getElementById('boothSize').value,
    status: document.getElementById('boothStatus').value
  };

  createBtn.disabled = true;
  createBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Creating...';

  try {
    const res = await fetch('/api/admin/create-booth', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify(payload)
    });

    const result = await res.json();

    if (!result.success) {
      throw new Error(result.message || 'Failed to create booth');
    }

    showSnackbar(result.message || 'Booth created successfully!', 'success');

    // Refresh booths list & grid
    loadBoothsForExpo(expoId, document.getElementById('expoTitle').textContent);

    // Reset form
    boothForm.reset();
    boothForm.classList.remove('was-validated');

  } catch (err) {
    showSnackbar(err.message || 'Something went wrong', 'error');
  } finally {
    createBtn.disabled = false;
    createBtn.innerHTML = '<i class="fas fa-plus me-2"></i>Create Booth';
  }
});

// ── Open Modal on Manage Button Click ───────────────────────────────────────
document.addEventListener('click', e => {
  if (e.target.classList.contains('manage-booth-btn')) {
    const expoId = e.target.dataset.id;
    const expoName = e.target.dataset.name;
    MyExpoId = expoId;

    loadBoothsForExpo(expoId, expoName);
    new bootstrap.Modal(document.getElementById('boothModal')).show();
  }
});

// ── Page Load ───────────────────────────────────────
window.addEventListener('DOMContentLoaded', loadExpos);
</script>

</body>
</html>