<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EventSphere — Browse Expos</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #e6f0ff 0%, #f5f7fa 100%);
      min-height: 100vh;
      padding: 2rem 1rem;
    }
    .header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .header h1 {
      font-weight: 700;
      color: #0066cc;
    }
    .search-box {
      max-width: 400px;
      margin: 0 auto 2rem;
    }
    .expo-card {
      border: none;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 25px rgba(0,0,0,0.08);
      transition: transform 0.25s, box-shadow 0.25s;
      height: 100%;
    }
    .expo-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    }
    .card-header {
      background: #0066cc;
      color: white;
      padding: 1.25rem;
      font-weight: 600;
    }
    .registered-badge {
      position: absolute;
      top: 10px;
      right: 10px;
      background: #28a745;
      color: white;
      padding: 0.35rem 0.9rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
    }
    .btn-view {
      border-color: #0066cc;
      color: #0066cc;
    }
    .btn-view:hover {
      background: #0066cc;
      color: white;
    }
    .btn-register {
      background: #0066cc;
      border: none;
    }
    .btn-register:disabled {
      background: #ccc;
      cursor: not-allowed;
    }
    .snackbar {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      min-width: 320px;
      padding: 16px 24px;
      border-radius: 10px;
      color: white;
      font-weight: 500;
      box-shadow: 0 6px 25px rgba(0,0,0,0.3);
      opacity: 0;
      transition: all 0.4s;
      z-index: 9999;
    }
    .snackbar.show { opacity: 1; }
    .snackbar.success { background: #2e7d32; }
    .snackbar.error   { background: #c62828; }

    @media (max-width: 992px) {
      .expo-card { margin-bottom: 1.5rem; }
    }
  </style>
</head>
<body>

<div class="container">
  <div class="header">
    <h1 class="display-5">Explore Upcoming Expos</h1>
    <p class="lead text-muted">Join exciting events and discover top exhibitors near you</p>
  </div>

  <div class="search-box">
    <div class="input-group input-group-lg">
      <input type="text" class="form-control" placeholder="Search Expo..." id="searchInput">
      <button class="btn btn-outline-primary" type="button">
        <i class="fas fa-search"></i>
      </button>
    </div>
  </div>

  <div class="row g-4" id="expoGrid">
    <!-- Expos cards load here -->
  </div>
</div>

<!-- Expo Details Modal -->
<div class="modal fade" id="expoModal" tabindex="-1" aria-labelledby="expoModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="expoModalLabel">Expo Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="modalBody">
        <!-- Dynamic content -->
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-register text-white" id="registerBtn">
          Register for this Expo
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Snackbar ───────────────────────────────────────
function showSnackbar(message, type = 'success') {
  const snack = document.createElement('div');
  snack.className = `snackbar ${type} show`;
  snack.textContent = message;
  document.body.appendChild(snack);
  setTimeout(() => snack.classList.remove('show'), 3200);
  setTimeout(() => snack.remove(), 3700);
}

// ── Load All Expos ───────────────────────────────────────
async function loadExpos() {
  const grid = document.getElementById('expoGrid');
  grid.innerHTML = `
    <div class="col-12 text-center py-5">
      <div class="spinner-border text-primary" role="status"></div>
      <p class="mt-3">Loading upcoming expos...</p>
    </div>
  `;

  try {
    const res = await fetch('/api/attendee/get-expo', {
      credentials: 'include'
    });

    const data = await res.json();

    if (!data.success) throw new Error(data.message || 'Failed to load expos');

    grid.innerHTML = '';

    data.data.forEach(expo => {
      const dateStr = expo.date ? new Date(expo.date).toLocaleDateString('en-PK', {
        day: 'numeric', month: 'long', year: 'numeric'
      }) : 'Date not available';

      const isRegistered = expo.reserved || false;

      const card = document.createElement('div');
      card.className = 'col-md-6 col-lg-4';
      card.innerHTML = `
        <div class="expo-card position-relative h-100">
          ${isRegistered ? '<span class="registered-badge">Registered ✔</span>' : ''}
          <div class="card-header">
            ${expo.title}
          </div>
          <div class="card-body">
            <p class="mb-2">
              <i class="fas fa-map-marker-alt me-2 text-primary"></i>
              ${expo.location || '—'}
            </p>
            <p class="mb-2">
              <i class="fas fa-palette me-2 text-primary"></i>
              ${expo.theme || 'General'}
            </p>
            <p class="mb-4">
              <i class="fas fa-calendar me-2 text-primary"></i>
              ${dateStr}
            </p>

            <button class="btn btn-view w-100 view-details-btn"
                    data-id="${expo._id}"
                    data-title="${expo.title}"
                    data-location="${expo.location || '—'}"
                    data-theme="${expo.theme || '—'}"
                    data-date="${dateStr}"
                    data-desc="${expo.description || 'No description available'}"
                    data-registered="${isRegistered}">
              <i class="fas fa-eye me-2"></i>View Details
            </button>
          </div>
        </div>
      `;
      grid.appendChild(card);
    });

  } catch (err) {
    grid.innerHTML = `
      <div class="col-12 text-center text-danger py-5">
        <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
        <h5>${err.message || 'Failed to load expos'}</h5>
      </div>
    `;
    showSnackbar('Could not load expos. Please try again.', 'error');
  }
}

// ── Open Expo Details Modal ───────────────────────────────────────
let currentExpoId = null;

document.addEventListener('click', e => {
  if (e.target.classList.contains('view-details-btn')) {
    const btn = e.target;
    currentExpoId = btn.dataset.id;

    document.getElementById('expoModalLabel').textContent = btn.dataset.title;

    const registered = btn.dataset.registered === 'true';

    document.getElementById('modalBody').innerHTML = `
      <div class="text-center mb-4">
        <h4>${btn.dataset.title}</h4>
      </div>
      <p><strong>Location:</strong> ${btn.dataset.location}</p>
      <p><strong>Theme:</strong> ${btn.dataset.theme}</p>
      <p><strong>Date:</strong> ${btn.dataset.date}</p>
      <hr>
      <p><strong>Description:</strong></p>
      <p class="text-muted">${btn.dataset.desc}</p>
    `;

    const regBtn = document.getElementById('registerBtn');
    if (registered) {
      regBtn.textContent = 'Registered ✔';
      regBtn.disabled = true;
      regBtn.classList.remove('btn-register');
      regBtn.classList.add('btn-success');
    } else {
      regBtn.textContent = 'Register for this Expo';
      regBtn.disabled = false;
      regBtn.classList.remove('btn-success');
      regBtn.classList.add('btn-register');
    }

    new bootstrap.Modal(document.getElementById('expoModal')).show();
  }
});

// ── Register for Expo ───────────────────────────────────────
document.getElementById('registerBtn').addEventListener('click', async () => {
  if (!currentExpoId) return;

  const btn = document.getElementById('registerBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Registering...';

  try {
    const res = await fetch('/api/attendee/reg-attendee-expo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'include',
      body: JSON.stringify({ expoId: currentExpoId })
    });

    const result = await res.json();

    if (!result.success) throw new Error(result.message || 'Registration failed');

    showSnackbar(result.message || 'Successfully registered for the expo!', 'success');

    // Update UI
    btn.textContent = 'Registered ✔';
    btn.disabled = true;
    btn.classList.remove('btn-register');
    btn.classList.add('btn-success');

    // Optional: reload cards to show updated badges
    loadExpos();

  } catch (err) {
    showSnackbar(err.message || 'Could not register. Please try again.', 'error');
  } finally {
    if (btn.textContent !== 'Registered ✔') {
      btn.disabled = false;
      btn.innerHTML = 'Register for this Expo';
    }
  }
});

// ── Page Load ───────────────────────────────────────
window.addEventListener('DOMContentLoaded', loadExpos);
</script>

</body>
</html>