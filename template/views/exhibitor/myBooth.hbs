<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EventSphere — My Booths</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #e6f0ff 0%, #f5f7fa 100%);
      min-height: 100vh;
      padding: 2rem 1rem;
    }
    .header {
      text-align: center;
      margin-bottom: 3rem;
    }
    .header h1 {
      font-weight: 700;
      color: #0066cc;
    }
    .booth-card {
      border: none;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 25px rgba(0,0,0,0.08);
      transition: transform 0.25s, box-shadow 0.25s;
      height: 100%;
    }
    .booth-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.12);
    }
    .card-header {
      background: linear-gradient(135deg, #0066cc, #004080);
      color: white;
      padding: 1.5rem;
      font-weight: 600;
      font-size: 1.25rem;
    }
    .card-body {
      padding: 1.75rem;
    }
    .booth-badge {
      font-size: 1.4rem;
      font-weight: 700;
      background: #0066cc;
      color: white;
      padding: 0.35rem 0.9rem;
      border-radius: 12px;
      display: inline-block;
      margin: 1rem 0;
    }
    .status-badge {
      font-size: 0.95rem;
      padding: 0.5rem 1rem;
    }
    .empty-state {
      text-align: center;
      padding: 5rem 1rem;
      background: white;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    }
    .snackbar {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      min-width: 320px;
      padding: 16px 24px;
      border-radius: 10px;
      color: white;
      font-weight: 500;
      box-shadow: 0 6px 25px rgba(0,0,0,0.3);
      opacity: 0;
      transition: all 0.4s;
      z-index: 9999;
    }
    .snackbar.show { opacity: 1; }
    .snackbar.success { background: #2e7d32; }
    .snackbar.error   { background: #c62828; }

    @media (max-width: 992px) {
      .booth-card { margin-bottom: 1.5rem; }
    }
  </style>
</head>
<body>

<div class="container">
  <div class="header">
    <h1 class="display-5">My Booths</h1>
    <p class="lead text-muted mb-4">View and manage the booths you have reserved for upcoming expos</p>
    <a href="/exhibitor/expoList" class="btn btn-outline-primary btn-lg px-4">
      <i class="fas fa-search me-2"></i>Browse More Expos
    </a>
  </div>

  <div class="row g-4" id="boothsContainer">
    <!-- Booths cards / empty state yahan load honge -->
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Snackbar Helper ───────────────────────────────────────
function showSnackbar(message, type = 'success') {
  const snack = document.createElement('div');
  snack.className = `snackbar ${type} show`;
  snack.textContent = message;
  document.body.appendChild(snack);
  setTimeout(() => snack.classList.remove('show'), 3200);
  setTimeout(() => snack.remove(), 3700);
}

// ── Load My Reserved Booths ───────────────────────────────────────
async function loadMyBooths() {
  const container = document.getElementById('boothsContainer');
  container.innerHTML = `
    <div class="col-12 text-center py-5">
      <div class="spinner-border text-primary" role="status"></div>
      <p class="mt-3">Loading your reserved booths...</p>
    </div>
  `;

  try {
    const res = await fetch('/api/exhibitor/my-booth', {
      credentials: 'include'  // agar JWT ya cookie auth hai
    });

    const result = await res.json();

    if (!result.success) {
      throw new Error(result.message || 'Failed to load your booths');
    }

    const booths = result.data || [];

    container.innerHTML = '';

    if (booths.length === 0) {
      container.innerHTML = `
        <div class="col-12">
          <div class="empty-state">
            <i class="fas fa-store-slash fa-4x text-muted mb-4"></i>
            <h4 class="mb-3">You haven't reserved any booths yet</h4>
            <p class="text-muted mb-4">Start exploring upcoming expos and book your space today!</p>
            <a href="/exhibitor/expoList" class="btn btn-primary btn-lg px-4">
              <i class="fas fa-search me-2"></i>Browse Available Expos
            </a>
          </div>
        </div>
      `;
      return;
    }

    booths.forEach(booth => {
      const expo = booth.expo || {};
      const dateStr = expo.date ? new Date(expo.date).toLocaleDateString('en-PK', {
        day: 'numeric', month: 'long', year: 'numeric'
      }) : 'Date not available';

      const card = document.createElement('div');
      card.className = 'col-md-6 col-lg-4';
      card.innerHTML = `
        <div class="booth-card h-100">
          <div class="card-header">
            ${expo.title || 'Untitled Expo'}
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <div>
                <small class="text-muted">Your Booth</small><br>
                <span class="booth-badge">🔵 ${booth.boothNumber || '—'}</span>
              </div>
              <span class="badge bg-success status-badge px-3 py-2">
                ${booth.status || 'Reserved'}
              </span>
            </div>

            <p class="mb-2">
              <i class="fas fa-map-marker-alt me-2 text-primary"></i>
              ${expo.location || 'Location not specified'}
            </p>
            <p class="mb-4">
              <i class="fas fa-calendar me-2 text-primary"></i>
              ${dateStr}
            </p>

            <a href="/exhibitor/expoList" class="btn btn-outline-primary w-100">
              <i class="fas fa-eye me-2"></i>View Expo Details
            </a>
          </div>
        </div>
      `;
      container.appendChild(card);
    });

  } catch (err) {
    console.error(err);
    container.innerHTML = `
      <div class="col-12 text-center text-danger py-5">
        <i class="fas fa-exclamation-triangle fa-3x mb-3"></i>
        <h5>${err.message || 'Failed to load your booths'}</h5>
        <p class="mt-3">Please try again later or contact support.</p>
      </div>
    `;
    showSnackbar('Could not load your reserved booths', 'error');
  }
}

// ── Page Load ───────────────────────────────────────
window.addEventListener('DOMContentLoaded', loadMyBooths);
</script>

</body>
</html>