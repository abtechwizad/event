<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>EventSphere — Become an Exhibitor</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(135deg, #e6f0ff 0%, #f5f7fa 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .main-card {
      max-width: 1100px;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(0,0,0,0.12);
    }
    .header {
      background: linear-gradient(135deg, #0066cc, #003366);
      color: white;
      padding: 2.5rem 2rem;
      text-align: center;
    }
    .header h2 { font-weight: 700; margin-bottom: 0.5rem; }
    .header p { opacity: 0.9; margin: 0; }
    .form-section, .preview-section {
      padding: 2.5rem;
      background: white;
    }
    .logo-upload {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      border: 3px dashed #0066cc;
      margin: 0 auto 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      background: #f8f9fa;
      transition: all 0.3s;
    }
    .logo-upload:hover { border-color: #0055b3; background: #e6f0ff; }
    .logo-preview {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }
    .upload-text {
      position: absolute;
      text-align: center;
      font-size: 0.85rem;
      color: #666;
      pointer-events: none;
    }
    .preview-card {
      border: 1px solid #dee2e6;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 15px rgba(0,0,0,0.06);
      text-align: center;
      padding: 1.5rem;
    }
    .preview-logo {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      object-fit: cover;
      margin-bottom: 1rem;
      border: 3px solid #0066cc;
    }
    .char-count {
      font-size: 0.85rem;
      color: #666;
      text-align: right;
      margin-top: 0.25rem;
    }
    .progress-bar-custom {
      height: 8px;
      background: #e9ecef;
      border-radius: 4px;
      margin: 1.5rem 0;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(to right, #0066cc, #4dabf7);
      width: 0%;
      transition: width 0.4s;
    }
    .btn-register {
      background: linear-gradient(90deg, #0066cc, #0055b3);
      border: none;
      padding: 0.9rem 2.5rem;
      font-size: 1.1rem;
      font-weight: 600;
    }
    .btn-register:hover {
      background: linear-gradient(90deg, #0055b3, #004494);
      transform: translateY(-2px);
    }
    .snackbar {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%);
      min-width: 320px;
      padding: 14px 24px;
      border-radius: 10px;
      color: white;
      font-weight: 500;
      box-shadow: 0 6px 25px rgba(0,0,0,0.25);
      opacity: 0;
      transition: all 0.4s ease;
      z-index: 9999;
    }
    .snackbar.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .snackbar.success { background: #2e7d32; }
    .snackbar.error   { background: #c62828; }

    @media (max-width: 992px) {
      .preview-section { display: none; }
      .form-section { padding: 2rem 1.5rem; }
    }
  </style>
</head>
<body>

<div class="main-card">
  <div class="header">
    <h2>Become an Exhibitor</h2>
    <p>Showcase your company at the event and reach thousands of attendees</p>
  </div>

  <div class="row g-0">
    <!-- Form Side -->
    <div class="col-lg-7 form-section">
      <form id="exhibitorForm" enctype="multipart/form-data" novalidate>
        <!-- Progress -->
        <div class="progress-bar-custom">
          <div class="progress-fill" id="progressFill"></div>
        </div>

        <!-- Logo Upload -->
        <label for="logoInput" class="logo-upload" id="logoDropZone">
          <input type="file" id="logoInput" accept="image/*" hidden>
          <img id="logoPreview" class="logo-preview" src="" alt="" style="display:none;">
          <div class="upload-text">
            <i class="fas fa-cloud-upload-alt fa-2x mb-2"></i><br>
            Upload Logo<br>(Click or Drag)
          </div>
        </label>

        <div class="row g-3">
          <div class="col-md-6">
            <label for="companyName" class="form-label">Company Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="companyName" placeholder="e.g. TechNova Solutions" required>
            <div class="invalid-feedback">Company name is required</div>
          </div>

          <div class="col-md-6">
            <label for="contactEmail" class="form-label">Contact Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="contactEmail" placeholder="company@example.com" required>
            <div class="invalid-feedback">Valid email is required</div>
          </div>
        </div>

        <div class="mt-4">
          <label for="description" class="form-label">Company Description <span class="text-danger">*</span></label>
          <textarea class="form-control" id="description" rows="6" 
                    placeholder="Tell visitors about your company, products/services, and what you'll showcase at the event..." 
                    maxlength="500" required></textarea>
          <div class="char-count"><span id="charCount">0</span>/500</div>
          <div class="invalid-feedback">Description is required (max 500 characters)</div>
        </div>

        <div class="text-center mt-5">
          <button type="submit" class="btn btn-register text-white" id="submitBtn">
            Register as Exhibitor <i class="fas fa-rocket ms-2"></i>
          </button>
        </div>
      </form>
    </div>

    <!-- Live Preview Side (desktop only) -->
    <div class="col-lg-5 preview-section d-none d-lg-block">
      <div class="preview-card">
        <h4 class="mb-4 text-center">Booth Preview</h4>
        
        <img id="previewLogo" src="" alt="Company Logo" class="preview-logo" style="display:none;">
        <div id="noLogoPlaceholder" class="preview-logo d-flex align-items-center justify-content-center bg-light text-muted">
          <i class="fas fa-building fa-2x"></i>
        </div>

        <h5 id="previewName" class="mt-3 mb-2">Your Company Name</h5>
        <p id="previewDesc" class="text-muted small">
          Your company description will appear here. Showcase your products, services, and innovations...
        </p>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Snackbar ───────────────────────────────────────
function showSnackbar(message, type = 'success') {
  const snack = document.createElement('div');
  snack.className = `snackbar ${type} show`;
  snack.textContent = message;
  document.body.appendChild(snack);
  setTimeout(() => snack.classList.remove('show'), 3200);
  setTimeout(() => snack.remove(), 3700);
}

// ── Logo Upload + Preview ───────────────────────────────────────
const logoDrop = document.getElementById('logoDropZone');
const logoInput = document.getElementById('logoInput');
const logoPreview = document.getElementById('logoPreview');
const previewLogo = document.getElementById('previewLogo');
const noLogoPlaceholder = document.getElementById('noLogoPlaceholder');

['click', 'dragenter', 'dragover', 'dragleave', 'drop'].forEach(evt => {
  logoDrop.addEventListener(evt, e => {
    e.preventDefault();
    e.stopPropagation();
    if(evt ==="click"){
        let input = document.getElementById("logoInput").dispatchEvent("click");
    }
    if (evt === 'dragenter' || evt === 'dragover') {
      logoDrop.style.borderColor = '#0055b3';
      logoDrop.style.background = '#e6f0ff';
    } else {
      logoDrop.style.borderColor = '#0066cc';
      logoDrop.style.background = '#f8f9fa';
    }
  });
});

logoDrop.addEventListener('drop', e => {
  const file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) handleLogo(file);
});

logoDrop.addEventListener('click', () => logoInput.click());
logoInput.addEventListener('change', e => {
  if (e.target.files[0]) handleLogo(e.target.files[0]);
});

function handleLogo(file) {
  const reader = new FileReader();
  reader.onload = e => {
    logoPreview.src = e.target.result;
    logoPreview.style.display = 'block';
    previewLogo.src = e.target.result;
    previewLogo.style.display = 'block';
    noLogoPlaceholder.style.display = 'none';
  };
  reader.readAsDataURL(file);
}

// ── Live Preview Updates ───────────────────────────────────────
document.getElementById('companyName').addEventListener('input', e => {
  document.getElementById('previewName').textContent = e.target.value || 'Your Company Name';
});

document.getElementById('description').addEventListener('input', e => {
  document.getElementById('previewDesc').textContent = e.target.value || 'Your company description will appear here...';
  document.getElementById('charCount').textContent = e.target.value.length;
});

// Progress feel (fake)
const inputs = document.querySelectorAll('#exhibitorForm input, #exhibitorForm textarea, #exhibitorForm select');
inputs.forEach(inp => {
  inp.addEventListener('input', updateProgress);
});

function updateProgress() {
  let filled = 0;
  inputs.forEach(inp => { if (inp.value.trim()) filled++; });
  const percent = Math.min((filled / inputs.length) * 100, 100);
  document.getElementById('progressFill').style.width = percent + '%';
}

// ── Submit Form ───────────────────────────────────────
const form = document.getElementById('exhibitorForm');
const submitBtn = document.getElementById('submitBtn');

form.addEventListener('submit', async e => {
  e.preventDefault();

  if (!form.checkValidity()) {
    form.classList.add('was-validated');
    return;
  }

  submitBtn.disabled = true;
  submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Registering...';

  const formData = new FormData();
  formData.append('companyName', document.getElementById('companyName').value.trim());
  formData.append('contactEmail', document.getElementById('contactEmail').value.trim());
  formData.append('description', document.getElementById('description').value.trim());

  const logoFile = document.getElementById('logoInput').files[0];
  if (logoFile) formData.append('logo', logoFile);

  try {
    const res = await fetch('/api/exhibitor/register-exhibitor', {
      method: 'POST',
      body: formData,
      credentials: 'include' // agar auth cookie/token use kar rahe ho
    });

    const result = await res.json();

    if (!result.success) {
      throw new Error(result.message || 'Registration failed');
    }

    showSnackbar(result.message || 'Registered successfully as Exhibitor!', 'success');

    // Optional: redirect ya form reset
    setTimeout(() => {
      form.reset();
      logoPreview.style.display = 'none';
      previewLogo.style.display = 'none';
      noLogoPlaceholder.style.display = 'flex';
      document.getElementById('previewName').textContent = 'Your Company Name';
      document.getElementById('previewDesc').textContent = 'Your company description...';
      document.getElementById('charCount').textContent = '0';
      document.getElementById('progressFill').style.width = '0%';
      form.classList.remove('was-validated');
    }, 1500);

  } catch (err) {
    showSnackbar(err.message || 'Something went wrong. Please try again.', 'error');
  } finally {
    submitBtn.disabled = false;
    submitBtn.innerHTML = 'Register as Exhibitor <i class="fas fa-rocket ms-2"></i>';
  }
});
</script>

</body>
</html>